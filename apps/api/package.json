    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@sinclair/typebox": "^0.34.41",
    "argon2": "^0.44.0",
    "bullmq": "^5.61.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
