{
  "name": "@easy-stream/showcase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24" },
  "scripts": {
    "cli": "node --import tsx src/cli.ts",
    "build": "corepack pnpm exec esbuild src/cli.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@easy-stream/media": "workspace:*",
    "@fastify/static": "^8.3.0",
    "fastify": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "esbuild": "^0.25.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
