{
  "name": "@easy-stream/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p ../contracts/tsconfig.json && tsc -p tsconfig.json",
    "test": "tsc -p ../contracts/tsconfig.json && vitest run",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@easy-stream/contracts": "workspace:*",
    "@sinclair/typebox": "^0.34.41",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
