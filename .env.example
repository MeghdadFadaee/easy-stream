NODE_ENV=development
HOST=0.0.0.0
PORT=3000
POSTGRES_PASSWORD=replace-with-a-long-alphanumeric-password
REPOSITORY_DRIVER=memory
# Production requires one HTTPS origin for the SPA, API, and media cookie path.
WEB_ORIGIN=http://localhost:5173
PUBLIC_ORIGIN=http://localhost:8080
GATEWAY_BIND_ADDRESS=0.0.0.0
DATABASE_URL=
REDIS_URL=redis://localhost:6379
ARCHIVE_ROOT=./movies
CACHE_ROOT=./data/cache
DERIVED_ROOT=./data/derived
METADATA_ROOT=./data/metadata
CATALOG_SNAPSHOT_PATH=./data/metadata/catalog.json
INVENTORY_SNAPSHOT_PATH=./data/metadata/inventory.json
PACKAGE_REGISTRY_PATH=./data/metadata/package-registry.json
MEDIA_COMMANDS_PATH=./data/metadata/media-commands.jsonl
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
PLAYBACK_PROFILE=cmaf-v1
# Use two different random hex/base64url values (for example: openssl rand -hex 32).
PLAYBACK_SIGNING_SECRET=replace-with-at-least-32-random-characters
MEDIA_AUTH_SHARED_SECRET=replace-with-another-32-random-character-secret
PLAYBACK_TTL_SECONDS=14400
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-production
ADMIN_SESSION_TTL_SECONDS=28800
TMDB_API_TOKEN=
TMDB_COMMERCIAL_LICENSE_CONFIRMED=false
MEDIA_PUBLIC_BASE_URL=http://localhost:8080/media
JIT_REMUX_CONCURRENCY=2
ENCODE_CONCURRENCY=1
CACHE_HIGH_WATERMARK=0.85
CACHE_LOW_WATERMARK=0.75
CACHE_MAX_BYTES=2147483648000
